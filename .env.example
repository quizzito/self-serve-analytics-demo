# Copy this file to .env and fill in your own key.
# .env is gitignored and will never be committed.

# Get a free key at https://build.nvidia.com (no credit card required)
NVIDIA_API_KEY=nvapi-your-key-here

# Optional: only needed if you switch the agent to use Claude directly
# instead of the free NVIDIA endpoint. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here